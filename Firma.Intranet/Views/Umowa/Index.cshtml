@model IEnumerable<Firma.Data.CRM.Umowa>
@{ ViewData["Title"] = "Umowy"; }

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="h4 mb-0"><i class="bi bi-file-earmark-text me-2"></i>Umowy</h2>
        <a asp-action="Create" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg"></i> Nowa umowa
        </a>
    </div>
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover table-striped mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>@Html.DisplayNameFor(m => m.DataPodpisania)</th>
                        <th>@Html.DisplayNameFor(m => m.TypUmowy)</th>
                        <th>Klient</th>
                        <th>@Html.DisplayNameFor(m => m.WartoscUmowy)</th>
                        <th class="text-end">Akcje</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.DataPodpisania.ToString("dd.MM.yyyy")</td>
                            <td>@item.TypUmowy</td>
                            <td>@item.Klient?.Imie @item.Klient?.Nazwisko</td>
                            <td>@item.WartoscUmowy.ToString("C")</td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@item.IdUmowy" class="btn btn-outline-info btn-sm"><i class="bi bi-eye"></i></a>
                                <a asp-action="Edit" asp-route-id="@item.IdUmowy" class="btn btn-outline-warning btn-sm"><i class="bi bi-pencil-square"></i></a>
                                <a asp-action="Delete" asp-route-id="@item.IdUmowy" class="btn btn-outline-danger btn-sm"><i class="bi bi-trash"></i></a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
