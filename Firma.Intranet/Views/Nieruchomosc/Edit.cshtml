@model Firma.Data.Nieruchomosci.Nieruchomosc
@{ ViewData["Title"] = "Edytuj nieruchomość"; }

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-warning text-dark">
                    <h5 class="mb-0"><i class="bi bi-pencil-square me-2"></i>Edytuj nieruchomość</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Edit">
                        <input type="hidden" asp-for="IdNieruchomosci" />
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none"></div>
                        <div class="mb-3">
                            <label asp-for="Tytul" class="form-label fw-semibold"></label>
                            <input asp-for="Tytul" class="form-control" />
                            <span asp-validation-for="Tytul" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Adres" class="form-label fw-semibold"></label>
                            <input asp-for="Adres" class="form-control" />
                            <span asp-validation-for="Adres" class="text-danger small"></span>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Cena" class="form-label fw-semibold"></label>
                                <input asp-for="Cena" class="form-control" />
                                <span asp-validation-for="Cena" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Powierzchnia" class="form-label fw-semibold"></label>
                                <input asp-for="Powierzchnia" class="form-control" />
                                <span asp-validation-for="Powierzchnia" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label asp-for="LiczbaIzb" class="form-label fw-semibold"></label>
                            <input asp-for="LiczbaIzb" class="form-control" type="number" />
                            <span asp-validation-for="LiczbaIzb" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="FotoURL" class="form-label fw-semibold"></label>
                            <input asp-for="FotoURL" class="form-control" />
                            <span asp-validation-for="FotoURL" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Opis" class="form-label fw-semibold"></label>
                            <textarea asp-for="Opis" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Opis" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="IdTypu" class="form-label fw-semibold"></label>
                            <select asp-for="IdTypu" asp-items="ViewBag.IdTypu" class="form-select"></select>
                            <span asp-validation-for="IdTypu" class="text-danger small"></span>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-warning"><i class="bi bi-floppy me-1"></i>Zapisz</button>
                            <a asp-action="Index" class="btn btn-outline-secondary">Anuluj</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
