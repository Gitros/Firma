@model Firma.Data.CRM.Oferta
@{ ViewData["Title"] = "Szczegóły oferty"; }

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0"><i class="bi bi-eye me-2"></i>Szczegóły oferty</h5>
                </div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-4">@Html.DisplayNameFor(m => m.DataWystawienia)</dt>
                        <dd class="col-sm-8">@Model.DataWystawienia.ToString("dd.MM.yyyy")</dd>
                        <dt class="col-sm-4">@Html.DisplayNameFor(m => m.Status)</dt>
                        <dd class="col-sm-8">
                            <span class="badge @(Model.Status == "Aktywna" ? "bg-success" : Model.Status == "Sprzedana" ? "bg-secondary" : "bg-warning text-dark")">
                                @Model.Status
                            </span>
                        </dd>
                        <dt class="col-sm-4">@Html.DisplayNameFor(m => m.Cena)</dt>
                        <dd class="col-sm-8">@Model.Cena.ToString("C")</dd>
                        <dt class="col-sm-4">Nieruchomość</dt>
                        <dd class="col-sm-8">@Model.Nieruchomosc?.Tytul</dd>
                        <dt class="col-sm-4">Agent</dt>
                        <dd class="col-sm-8">@Model.Pracownik?.Imie @Model.Pracownik?.Nazwisko</dd>
                    </dl>
                    <div class="d-flex gap-2 mt-3">
                        <a asp-action="Edit" asp-route-id="@Model.IdOferty" class="btn btn-warning btn-sm"><i class="bi bi-pencil-square me-1"></i>Edytuj</a>
                        <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-list-ul me-1"></i>Wróć</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
