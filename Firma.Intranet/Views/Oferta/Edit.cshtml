@model Firma.Data.CRM.Oferta
@{ ViewData["Title"] = "Edytuj ofertę"; }

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm">
                <div class="card-header bg-warning text-dark">
                    <h5 class="mb-0"><i class="bi bi-pencil-square me-2"></i>Edytuj ofertę</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Edit">
                        <input type="hidden" asp-for="IdOferty" />
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none"></div>
                        <div class="mb-3">
                            <label asp-for="DataWystawienia" class="form-label fw-semibold"></label>
                            <input asp-for="DataWystawienia" class="form-control" type="date" />
                            <span asp-validation-for="DataWystawienia" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Status" class="form-label fw-semibold"></label>
                            <select asp-for="Status" class="form-select">
                                <option value="Aktywna">Aktywna</option>
                                <option value="Zarezerwowana">Zarezerwowana</option>
                                <option value="Sprzedana">Sprzedana</option>
                                <option value="Wycofana">Wycofana</option>
                            </select>
                            <span asp-validation-for="Status" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Cena" class="form-label fw-semibold"></label>
                            <input asp-for="Cena" class="form-control" />
                            <span asp-validation-for="Cena" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="IdNieruchomosci" class="form-label fw-semibold"></label>
                            <select asp-for="IdNieruchomosci" asp-items="ViewBag.IdNieruchomosci" class="form-select"></select>
                            <span asp-validation-for="IdNieruchomosci" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="IdPracownika" class="form-label fw-semibold"></label>
                            <select asp-for="IdPracownika" asp-items="ViewBag.IdPracownika" class="form-select"></select>
                            <span asp-validation-for="IdPracownika" class="text-danger small"></span>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-warning"><i class="bi bi-floppy me-1"></i>Zapisz</button>
                            <a asp-action="Index" class="btn btn-outline-secondary">Anuluj</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
