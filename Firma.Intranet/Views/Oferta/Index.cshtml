@model IEnumerable<Firma.Data.CRM.Oferta>
@{ ViewData["Title"] = "Oferty"; }

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="h4 mb-0"><i class="bi bi-clipboard-check me-2"></i>Oferty sprzedaży</h2>
        <a asp-action="Create" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg"></i> Nowa oferta
        </a>
    </div>
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover table-striped mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>@Html.DisplayNameFor(m => m.DataWystawienia)</th>
                        <th>Nieruchomość</th>
                        <th>Agent</th>
                        <th>@Html.DisplayNameFor(m => m.Status)</th>
                        <th>@Html.DisplayNameFor(m => m.Cena)</th>
                        <th class="text-end">Akcje</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.DataWystawienia.ToString("dd.MM.yyyy")</td>
                            <td>@item.Nieruchomosc?.Tytul</td>
                            <td>@item.Pracownik?.Nazwisko</td>
                            <td>
                                <span class="badge @(item.Status == "Aktywna" ? "bg-success" : item.Status == "Sprzedana" ? "bg-secondary" : "bg-warning text-dark")">
                                    @item.Status
                                </span>
                            </td>
                            <td>@item.Cena.ToString("C")</td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@item.IdOferty" class="btn btn-outline-info btn-sm"><i class="bi bi-eye"></i></a>
                                <a asp-action="Edit" asp-route-id="@item.IdOferty" class="btn btn-outline-warning btn-sm"><i class="bi bi-pencil-square"></i></a>
                                <a asp-action="Delete" asp-route-id="@item.IdOferty" class="btn btn-outline-danger btn-sm"><i class="bi bi-trash"></i></a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
