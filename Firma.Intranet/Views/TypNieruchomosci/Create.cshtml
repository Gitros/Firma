@model Firma.Data.Nieruchomosci.TypNieruchomosci
@{ ViewData["Title"] = "Nowy typ nieruchomości"; }

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-plus-lg me-2"></i>Nowy typ nieruchomości</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none"></div>
                        <div class="mb-3">
                            <label asp-for="Nazwa" class="form-label fw-semibold"></label>
                            <input asp-for="Nazwa" class="form-control" />
                            <span asp-validation-for="Nazwa" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Opis" class="form-label fw-semibold"></label>
                            <textarea asp-for="Opis" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Opis" class="text-danger small"></span>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary"><i class="bi bi-floppy me-1"></i>Zapisz</button>
                            <a asp-action="Index" class="btn btn-outline-secondary">Anuluj</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
