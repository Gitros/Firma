@model Firma.Data.CMS.Strona
@{ ViewData["Title"] = "Szczegóły strony"; }

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0"><i class="bi bi-eye me-2"></i>Szczegóły strony CMS</h5>
                </div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-4">@Html.DisplayNameFor(m => m.LinkTytul)</dt>
                        <dd class="col-sm-8">@Html.DisplayFor(m => m.LinkTytul)</dd>
                        <dt class="col-sm-4">@Html.DisplayNameFor(m => m.Tytul)</dt>
                        <dd class="col-sm-8">@Html.DisplayFor(m => m.Tytul)</dd>
                        <dt class="col-sm-4">@Html.DisplayNameFor(m => m.Tresc)</dt>
                        <dd class="col-sm-8">@Html.DisplayFor(m => m.Tresc)</dd>
                        <dt class="col-sm-4">@Html.DisplayNameFor(m => m.Pozycja)</dt>
                        <dd class="col-sm-8">@Html.DisplayFor(m => m.Pozycja)</dd>
                    </dl>
                    <div class="d-flex gap-2 mt-3">
                        <a asp-action="Edit" asp-route-id="@Model.IdStrony" class="btn btn-warning btn-sm"><i class="bi bi-pencil-square me-1"></i>Edytuj</a>
                        <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-list-ul me-1"></i>Wróć</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
