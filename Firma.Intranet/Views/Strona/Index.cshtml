@model IEnumerable<Firma.Data.CMS.Strona>
@{ ViewData["Title"] = "Strony CMS"; }

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="h4 mb-0"><i class="bi bi-file-text me-2"></i>Strony CMS</h2>
        <a asp-action="Create" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg"></i> Dodaj stronę
        </a>
    </div>
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover table-striped mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>@Html.DisplayNameFor(m => m.Pozycja)</th>
                        <th>@Html.DisplayNameFor(m => m.LinkTytul)</th>
                        <th>@Html.DisplayNameFor(m => m.Tytul)</th>
                        <th class="text-end">Akcje</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Pozycja</td>
                            <td>@item.LinkTytul</td>
                            <td>@item.Tytul</td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@item.IdStrony" class="btn btn-outline-info btn-sm"><i class="bi bi-eye"></i></a>
                                <a asp-action="Edit" asp-route-id="@item.IdStrony" class="btn btn-outline-warning btn-sm"><i class="bi bi-pencil-square"></i></a>
                                <a asp-action="Delete" asp-route-id="@item.IdStrony" class="btn btn-outline-danger btn-sm"><i class="bi bi-trash"></i></a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
