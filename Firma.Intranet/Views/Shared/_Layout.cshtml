@{
    var ctrl = ViewContext.RouteData.Values["controller"]?.ToString();
    var act = ViewContext.RouteData.Values["action"]?.ToString();
    string Active(string a) => act == a && ctrl == "Home" ? "active" : "";
    string ActiveCtrl(string c) => ctrl == c ? "active" : "";
}
<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - NieruchomościPro CRM</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Firma.Intranet.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="app-shell">
        <aside class="sidebar d-none d-lg-flex flex-column">
            <div class="sidebar-brand">
                <i class="bi bi-buildings-fill"></i>
                <div>
                    <div class="brand-title">NieruchomościPro</div>
                    <div class="brand-sub">CRM v1.0</div>
                </div>
            </div>
            <nav class="sidebar-nav">
                <div class="nav-section">Główne</div>
                <a class="nav-link @Active("Index")" asp-controller="Home" asp-action="Index"><i class="bi bi-grid-1x2-fill"></i> Dashboard</a>
                <a class="nav-link @Active("Pracownicy")" asp-controller="Home" asp-action="Pracownicy"><i class="bi bi-people-fill"></i> Pracownicy</a>
                <a class="nav-link @Active("Raporty")" asp-controller="Home" asp-action="Raporty"><i class="bi bi-bar-chart-fill"></i> Raporty</a>
                <div class="nav-section mt-3">CMS</div>
                <a class="nav-link @ActiveCtrl("Aktualnosc")" asp-controller="Aktualnosc" asp-action="Index"><i class="bi bi-newspaper"></i> Aktualności</a>
                <a class="nav-link @ActiveCtrl("Strona")" asp-controller="Strona" asp-action="Index"><i class="bi bi-file-text"></i> Strony</a>
                <div class="nav-section mt-3">Nieruchomości</div>
                <a class="nav-link @ActiveCtrl("TypNieruchomosci")" asp-controller="TypNieruchomosci" asp-action="Index"><i class="bi bi-tags"></i> Typy</a>
                <a class="nav-link @ActiveCtrl("Nieruchomosc")" asp-controller="Nieruchomosc" asp-action="Index"><i class="bi bi-house-door"></i> Nieruchomości</a>
                <div class="nav-section mt-3">CRM</div>
                <a class="nav-link @ActiveCtrl("Klient")" asp-controller="Klient" asp-action="Index"><i class="bi bi-person-lines-fill"></i> Klienci</a>
                <a class="nav-link @ActiveCtrl("Pracownik")" asp-controller="Pracownik" asp-action="Index"><i class="bi bi-people"></i> Pracownicy</a>
                <a class="nav-link @ActiveCtrl("Oferta")" asp-controller="Oferta" asp-action="Index"><i class="bi bi-clipboard-check"></i> Oferty</a>
                <a class="nav-link @ActiveCtrl("Umowa")" asp-controller="Umowa" asp-action="Index"><i class="bi bi-file-earmark-text"></i> Umowy</a>
                <div class="nav-section mt-3">System</div>
                <a class="nav-link @Active("Ustawienia")" asp-controller="Home" asp-action="Ustawienia"><i class="bi bi-gear-fill"></i> Ustawienia</a>
                <a class="nav-link" href="#"><i class="bi bi-question-circle-fill"></i> Pomoc</a>
            </nav>
            <div class="sidebar-foot">
                <div class="user-mini">
                    <div class="avatar">JK</div>
                    <div>
                        <div class="user-name">Jan Kowalski</div>
                        <div class="user-role">Administrator</div>
                    </div>
                </div>
            </div>
        </aside>

        <div class="offcanvas offcanvas-start sidebar sidebar-offcanvas" tabindex="-1" id="sideNav">
            <div class="offcanvas-header sidebar-brand p-3">
                <i class="bi bi-buildings-fill"></i>
                <div>
                    <div class="brand-title">NieruchomościPro</div>
                    <div class="brand-sub">CRM v1.0</div>
                </div>
                <button type="button" class="btn-close btn-close-white ms-auto" data-bs-dismiss="offcanvas" aria-label="Zamknij"></button>
            </div>
            <div class="offcanvas-body p-0">
                <nav class="sidebar-nav">
                    <div class="nav-section">Główne</div>
                    <a class="nav-link @Active("Index")" asp-controller="Home" asp-action="Index"><i class="bi bi-grid-1x2-fill"></i> Dashboard</a>
                    <a class="nav-link @Active("Pracownicy")" asp-controller="Home" asp-action="Pracownicy"><i class="bi bi-people-fill"></i> Pracownicy</a>
                    <a class="nav-link @Active("Raporty")" asp-controller="Home" asp-action="Raporty"><i class="bi bi-bar-chart-fill"></i> Raporty</a>
                    <div class="nav-section mt-3">CMS</div>
                    <a class="nav-link @ActiveCtrl("Aktualnosc")" asp-controller="Aktualnosc" asp-action="Index"><i class="bi bi-newspaper"></i> Aktualności</a>
                    <a class="nav-link @ActiveCtrl("Strona")" asp-controller="Strona" asp-action="Index"><i class="bi bi-file-text"></i> Strony</a>
                    <div class="nav-section mt-3">Nieruchomości</div>
                    <a class="nav-link @ActiveCtrl("TypNieruchomosci")" asp-controller="TypNieruchomosci" asp-action="Index"><i class="bi bi-tags"></i> Typy</a>
                    <a class="nav-link @ActiveCtrl("Nieruchomosc")" asp-controller="Nieruchomosc" asp-action="Index"><i class="bi bi-house-door"></i> Nieruchomości</a>
                    <div class="nav-section mt-3">CRM</div>
                    <a class="nav-link @ActiveCtrl("Klient")" asp-controller="Klient" asp-action="Index"><i class="bi bi-person-lines-fill"></i> Klienci</a>
                    <a class="nav-link @ActiveCtrl("Pracownik")" asp-controller="Pracownik" asp-action="Index"><i class="bi bi-people"></i> Pracownicy</a>
                    <a class="nav-link @ActiveCtrl("Oferta")" asp-controller="Oferta" asp-action="Index"><i class="bi bi-clipboard-check"></i> Oferty</a>
                    <a class="nav-link @ActiveCtrl("Umowa")" asp-controller="Umowa" asp-action="Index"><i class="bi bi-file-earmark-text"></i> Umowy</a>
                    <div class="nav-section mt-3">System</div>
                    <a class="nav-link @Active("Ustawienia")" asp-controller="Home" asp-action="Ustawienia"><i class="bi bi-gear-fill"></i> Ustawienia</a>
                </nav>
            </div>
        </div>

        <!-- Main column -->
        <div class="app-main">
            <header class="topbar">
                <button class="btn btn-light d-lg-none me-2" type="button" data-bs-toggle="offcanvas" data-bs-target="#sideNav" aria-label="Otwórz menu">
                    <i class="bi bi-list"></i>
                </button>
                <div class="page-title">
                    <h1>@ViewData["Title"]</h1>
                    <span class="page-sub">@(ViewData["Subtitle"] ?? "Panel administracyjny")</span>
                </div>
                <div class="topbar-search d-none d-md-flex">
                    <i class="bi bi-search"></i>
                    <input type="text" placeholder="Szukaj klienta, oferty, pracownika..." />
                </div>
                <div class="topbar-actions">
                    <button class="topbar-icon" aria-label="Powiadomienia"><i class="bi bi-bell-fill"></i><span class="dot"></span></button>
                    <button class="topbar-icon" aria-label="Wiadomości"><i class="bi bi-envelope-fill"></i></button>
                    <div class="dropdown">
                        <button class="user-pill dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <span class="avatar avatar-sm">JK</span>
                            <span class="d-none d-md-inline">Jan Kowalski</span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" href="#"><i class="bi bi-person me-2"></i>Mój profil</a></li>
                            <li><a class="dropdown-item" asp-controller="Home" asp-action="Ustawienia"><i class="bi bi-gear me-2"></i>Ustawienia</a></li>
                            <li><hr class="dropdown-divider" /></li>
                            <li><a class="dropdown-item text-danger" href="#"><i class="bi bi-box-arrow-right me-2"></i>Wyloguj</a></li>
                        </ul>
                    </div>
                </div>
            </header>

            <main class="content-area">
                @RenderBody()
            </main>

            <footer class="app-footer">
                <span>NieruchomościPro CRM <strong>v1.0.0</strong></span>
                <span class="text-muted">© @DateTime.Now.Year · Wszystkie prawa zastrzeżone</span>
            </footer>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
