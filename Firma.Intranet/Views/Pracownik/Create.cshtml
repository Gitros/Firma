@model Firma.Data.CRM.Pracownik
@{ ViewData["Title"] = "Nowy pracownik"; }

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-person-plus me-2"></i>Nowy pracownik</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none"></div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Imie" class="form-label fw-semibold"></label>
                                <input asp-for="Imie" class="form-control" />
                                <span asp-validation-for="Imie" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Nazwisko" class="form-label fw-semibold"></label>
                                <input asp-for="Nazwisko" class="form-control" />
                                <span asp-validation-for="Nazwisko" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Stanowisko" class="form-label fw-semibold"></label>
                            <input asp-for="Stanowisko" class="form-control" />
                            <span asp-validation-for="Stanowisko" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Email" class="form-label fw-semibold"></label>
                            <input asp-for="Email" class="form-control" type="email" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="DataZatrudnienia" class="form-label fw-semibold"></label>
                            <input asp-for="DataZatrudnienia" class="form-control" type="date" />
                            <span asp-validation-for="DataZatrudnienia" class="text-danger small"></span>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary"><i class="bi bi-floppy me-1"></i>Zapisz</button>
                            <a asp-action="Index" class="btn btn-outline-secondary">Anuluj</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
