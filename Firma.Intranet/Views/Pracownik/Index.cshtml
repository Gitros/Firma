@model IEnumerable<Firma.Data.CRM.Pracownik>
@{ ViewData["Title"] = "Agenci / Pracownicy"; }

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="h4 mb-0"><i class="bi bi-people me-2"></i>Agenci / Pracownicy</h2>
        <a asp-action="Create" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg"></i> Dodaj pracownika
        </a>
    </div>
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover table-striped mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>@Html.DisplayNameFor(m => m.Imie)</th>
                        <th>@Html.DisplayNameFor(m => m.Nazwisko)</th>
                        <th>@Html.DisplayNameFor(m => m.Stanowisko)</th>
                        <th>@Html.DisplayNameFor(m => m.Email)</th>
                        <th>@Html.DisplayNameFor(m => m.DataZatrudnienia)</th>
                        <th class="text-end">Akcje</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Imie</td>
                            <td>@item.Nazwisko</td>
                            <td>@item.Stanowisko</td>
                            <td>@item.Email</td>
                            <td>@item.DataZatrudnienia.ToString("dd.MM.yyyy")</td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@item.IdPracownika" class="btn btn-outline-info btn-sm"><i class="bi bi-eye"></i></a>
                                <a asp-action="Edit" asp-route-id="@item.IdPracownika" class="btn btn-outline-warning btn-sm"><i class="bi bi-pencil-square"></i></a>
                                <a asp-action="Delete" asp-route-id="@item.IdPracownika" class="btn btn-outline-danger btn-sm"><i class="bi bi-trash"></i></a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
