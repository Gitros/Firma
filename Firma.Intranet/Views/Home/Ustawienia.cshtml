@{
    ViewData["Title"] = "Ustawienia";
    ViewData["Subtitle"] = "Profil użytkownika i konfiguracja systemu";
}

<div class="panel">
    <ul class="nav nav-tabs px-3 pt-2" id="settingsTabs" role="tablist">
        <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-profil" type="button"><i class="bi bi-person-circle me-1"></i> Profil</button></li>
        <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-pow" type="button"><i class="bi bi-bell me-1"></i> Powiadomienia</button></li>
        <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-bezp" type="button"><i class="bi bi-shield-lock me-1"></i> Bezpieczeństwo</button></li>
        <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-sys" type="button"><i class="bi bi-sliders me-1"></i> System</button></li>
    </ul>

    <div class="tab-content p-4">
        <!-- Profil -->
        <div class="tab-pane fade show active" id="tab-profil">
            <div class="row g-4">
                <div class="col-md-3 text-center">
                    <div class="avatar mx-auto mb-3" style="width: 110px; height: 110px; font-size: 2.2rem;">JK</div>
                    <button class="btn btn-light btn-sm w-100"><i class="bi bi-camera me-1"></i> Zmień zdjęcie</button>
                    <button class="btn btn-link text-danger btn-sm mt-1">Usuń</button>
                </div>
                <div class="col-md-9">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Imię</label>
                            <input type="text" class="form-control" value="Jan" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Nazwisko</label>
                            <input type="text" class="form-control" value="Kowalski" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Email służbowy</label>
                            <input type="email" class="form-control" value="j.kowalski@nieruchomosciPro.pl" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Telefon</label>
                            <input type="tel" class="form-control" value="+48 600 100 100" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Stanowisko</label>
                            <input type="text" class="form-control" value="Administrator systemu" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Oddział</label>
                            <select class="form-select">
                                <option>Nowy Sącz (główny)</option>
                                <option>Kraków</option>
                                <option>Tarnów</option>
                                <option>Zakopane</option>
                            </select>
                        </div>
                        <div class="col-md-12">
                            <label class="form-label">Bio</label>
                            <textarea class="form-control" rows="3" placeholder="Krótki opis...">Administrator systemu CRM od 2018 roku. Specjalizacja: integracje, automatyzacja procesów sprzedażowych.</textarea>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Powiadomienia -->
        <div class="tab-pane fade" id="tab-pow">
            <h6 class="mb-3">Kanały powiadomień</h6>
            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <div class="d-flex justify-content-between align-items-center p-3 border rounded">
                        <div>
                            <div class="fw-semibold"><i class="bi bi-envelope text-primary me-2"></i>Email</div>
                            <div class="small text-muted">Codzienny digest oraz alerty pilne</div>
                        </div>
                        <div class="form-check form-switch m-0"><input class="form-check-input" type="checkbox" checked /></div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="d-flex justify-content-between align-items-center p-3 border rounded">
                        <div>
                            <div class="fw-semibold"><i class="bi bi-bell text-primary me-2"></i>Powiadomienia push</div>
                            <div class="small text-muted">Natychmiastowe alerty w przeglądarce</div>
                        </div>
                        <div class="form-check form-switch m-0"><input class="form-check-input" type="checkbox" checked /></div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="d-flex justify-content-between align-items-center p-3 border rounded">
                        <div>
                            <div class="fw-semibold"><i class="bi bi-phone text-primary me-2"></i>SMS</div>
                            <div class="small text-muted">Tylko alerty o najwyższym priorytecie</div>
                        </div>
                        <div class="form-check form-switch m-0"><input class="form-check-input" type="checkbox" /></div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="d-flex justify-content-between align-items-center p-3 border rounded">
                        <div>
                            <div class="fw-semibold"><i class="bi bi-slack text-primary me-2"></i>Slack</div>
                            <div class="small text-muted">Integracja z kanałem #crm-alerts</div>
                        </div>
                        <div class="form-check form-switch m-0"><input class="form-check-input" type="checkbox" checked /></div>
                    </div>
                </div>
            </div>

            <h6 class="mb-3 mt-4">Typy zdarzeń</h6>
            <div class="row g-2">
                <div class="col-md-6"><div class="form-check"><input class="form-check-input" type="checkbox" checked id="ev1" /><label for="ev1" class="form-check-label">Nowa transakcja zakończona</label></div></div>
                <div class="col-md-6"><div class="form-check"><input class="form-check-input" type="checkbox" checked id="ev2" /><label for="ev2" class="form-check-label">Nowy klient zarejestrowany</label></div></div>
                <div class="col-md-6"><div class="form-check"><input class="form-check-input" type="checkbox" checked id="ev3" /><label for="ev3" class="form-check-label">Wygasająca umowa najmu</label></div></div>
                <div class="col-md-6"><div class="form-check"><input class="form-check-input" type="checkbox" id="ev4" /><label for="ev4" class="form-check-label">Każda nowa oferta dodana do systemu</label></div></div>
                <div class="col-md-6"><div class="form-check"><input class="form-check-input" type="checkbox" checked id="ev5" /><label for="ev5" class="form-check-label">Tygodniowy raport zespołu</label></div></div>
                <div class="col-md-6"><div class="form-check"><input class="form-check-input" type="checkbox" id="ev6" /><label for="ev6" class="form-check-label">Aktualizacje systemu i wersji</label></div></div>
            </div>
        </div>

        <!-- Bezpieczeństwo -->
        <div class="tab-pane fade" id="tab-bezp">
            <div class="row g-4">
                <div class="col-md-6">
                    <h6>Zmiana hasła</h6>
                    <div class="mb-3">
                        <label class="form-label">Aktualne hasło</label>
                        <input type="password" class="form-control" placeholder="••••••••" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Nowe hasło</label>
                        <input type="password" class="form-control" />
                        <div class="form-text">Min. 12 znaków, wielka litera, cyfra, znak specjalny</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Powtórz nowe hasło</label>
                        <input type="password" class="form-control" />
                    </div>
                </div>
                <div class="col-md-6">
                    <h6>Uwierzytelnianie dwuskładnikowe (2FA)</h6>
                    <div class="d-flex justify-content-between align-items-center p-3 border rounded mb-2">
                        <div>
                            <div class="fw-semibold">Aplikacja autoryzacyjna</div>
                            <div class="small text-muted">Google Authenticator / Authy</div>
                        </div>
                        <span class="badge-status active">Włączone</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center p-3 border rounded mb-2">
                        <div>
                            <div class="fw-semibold">SMS jako zapasowy kanał</div>
                            <div class="small text-muted">+48 600 100 *** </div>
                        </div>
                        <div class="form-check form-switch m-0"><input class="form-check-input" type="checkbox" /></div>
                    </div>
                    <h6 class="mt-4">Aktywne sesje</h6>
                    <div class="small text-muted">Windows · Edge · Nowy Sącz · teraz</div>
                    <div class="small text-muted">iPhone · Safari · 2 godz. temu</div>
                    <button class="btn btn-link text-danger p-0 mt-2 small">Wyloguj wszystkie inne sesje</button>
                </div>
            </div>
        </div>

        <!-- System -->
        <div class="tab-pane fade" id="tab-sys">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Język interfejsu</label>
                    <select class="form-select">
                        <option>Polski</option>
                        <option>English</option>
                        <option>Deutsch</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Strefa czasowa</label>
                    <select class="form-select">
                        <option>Europe/Warsaw (UTC+1)</option>
                        <option>Europe/London (UTC+0)</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Format daty</label>
                    <select class="form-select">
                        <option>YYYY-MM-DD</option>
                        <option>DD.MM.YYYY</option>
                        <option>MM/DD/YYYY</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Waluta domyślna</label>
                    <select class="form-select">
                        <option>PLN — złoty polski</option>
                        <option>EUR — euro</option>
                        <option>USD — dolar</option>
                    </select>
                </div>
                <div class="col-md-12">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" id="dark" />
                        <label for="dark" class="form-check-label">Tryb ciemny (eksperymentalne)</label>
                    </div>
                </div>
                <div class="col-md-12">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" id="auto" checked />
                        <label for="auto" class="form-check-label">Automatyczne zapisywanie formularzy co 30 sekund</label>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="panel-head" style="border-top: 1px solid var(--border); border-bottom: none;">
        <button class="btn btn-link text-muted">Anuluj</button>
        <div class="d-flex gap-2">
            <button class="btn btn-light"><i class="bi bi-arrow-counterclockwise me-1"></i> Resetuj</button>
            <button class="btn btn-accent"><i class="bi bi-check-lg me-1"></i> Zapisz zmiany</button>
        </div>
    </div>
</div>
