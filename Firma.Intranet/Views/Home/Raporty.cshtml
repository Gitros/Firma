@{
    ViewData["Title"] = "Raporty";
    ViewData["Subtitle"] = "Analityka sprzedaży, zespołu i ofert";
}

<div class="section-h">
    <div class="d-flex gap-2">
        <select class="form-select" style="max-width: 200px;">
            <option>Ostatnie 12 miesięcy</option>
            <option>Ostatni kwartał</option>
            <option>Bieżący rok</option>
            <option>Niestandardowy zakres</option>
        </select>
        <select class="form-select" style="max-width: 180px;">
            <option>Wszystkie oddziały</option>
            <option>Nowy Sącz</option>
            <option>Kraków</option>
            <option>Tarnów</option>
            <option>Zakopane</option>
        </select>
    </div>
    <div class="d-flex gap-2">
        <button class="btn btn-light"><i class="bi bi-printer me-1"></i> Drukuj</button>
        <button class="btn btn-light"><i class="bi bi-file-earmark-pdf me-1"></i> Export PDF</button>
        <button class="btn btn-accent"><i class="bi bi-cloud-download me-1"></i> Pobierz raport</button>
    </div>
</div>

<!-- Top KPI strip -->
<div class="row g-3 mb-4">
    <div class="col-sm-4">
        <div class="tile">
            <div class="tile-label">Sprzedaż łączna (rok)</div>
            <div class="tile-value">14.8 mln</div>
            <span class="tile-trend up"><i class="bi bi-arrow-up"></i> 23.4% r/r</span>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="tile">
            <div class="tile-label">Średni czas sprzedaży</div>
            <div class="tile-value">42 dni</div>
            <span class="tile-trend down"><i class="bi bi-arrow-down"></i> 8 dni r/r</span>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="tile">
            <div class="tile-label">Konwersja zapytań</div>
            <div class="tile-value">31.2%</div>
            <span class="tile-trend up"><i class="bi bi-arrow-up"></i> 4.1 pp r/r</span>
        </div>
    </div>
</div>

<!-- Bar chart + Top agents -->
<div class="row g-3 mb-4">
    <div class="col-lg-7">
        <div class="panel">
            <div class="panel-head">
                <div>
                    <h5>Sprzedaż miesięczna 2026</h5>
                    <span class="small text-muted">Wartość transakcji w mln zł</span>
                </div>
                <div class="d-flex align-items-center gap-3 small text-muted">
                    <span><i class="bi bi-square-fill text-primary"></i> Sprzedaż</span>
                </div>
            </div>
            <div class="panel-body">
                <div class="bar-chart">
                    <div class="bar-col"><div class="bar" style="height: 45%;"></div><div class="bar-label">Sty</div></div>
                    <div class="bar-col"><div class="bar" style="height: 60%;"></div><div class="bar-label">Lut</div></div>
                    <div class="bar-col"><div class="bar" style="height: 38%;"></div><div class="bar-label">Mar</div></div>
                    <div class="bar-col"><div class="bar" style="height: 75%;"></div><div class="bar-label">Kwi</div></div>
                    <div class="bar-col"><div class="bar" style="height: 85%;"></div><div class="bar-label">Maj</div></div>
                    <div class="bar-col"><div class="bar" style="height: 70%;"></div><div class="bar-label">Cze</div></div>
                    <div class="bar-col"><div class="bar" style="height: 55%;"></div><div class="bar-label">Lip</div></div>
                    <div class="bar-col"><div class="bar" style="height: 65%;"></div><div class="bar-label">Sie</div></div>
                    <div class="bar-col"><div class="bar" style="height: 80%;"></div><div class="bar-label">Wrz</div></div>
                    <div class="bar-col"><div class="bar" style="height: 90%;"></div><div class="bar-label">Paź</div></div>
                    <div class="bar-col"><div class="bar" style="height: 100%;"></div><div class="bar-label">Lis</div></div>
                    <div class="bar-col"><div class="bar" style="height: 78%;"></div><div class="bar-label">Gru</div></div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="panel">
            <div class="panel-head">
                <h5>Top agenci (Q1 2026)</h5>
                <a href="#" class="text-decoration-none small">Pełny ranking</a>
            </div>
            <div class="panel-body">
                <div class="agent-row">
                    <span class="avatar avatar-sm">AK</span>
                    <div class="agent-info">
                        <div class="agent-name">Anna Kowalska</div>
                        <div class="agent-meta">Kraków · 14 transakcji</div>
                    </div>
                    <div class="agent-bar"><div class="progress"><div class="progress-bar" style="width: 95%;"></div></div></div>
                    <div class="agent-value">3.12 mln</div>
                </div>
                <div class="agent-row">
                    <span class="avatar avatar-sm">MW</span>
                    <div class="agent-info">
                        <div class="agent-name">Marcin Wójcik</div>
                        <div class="agent-meta">Nowy Sącz · 9 transakcji</div>
                    </div>
                    <div class="agent-bar"><div class="progress"><div class="progress-bar" style="width: 88%;"></div></div></div>
                    <div class="agent-value">2.85 mln</div>
                </div>
                <div class="agent-row">
                    <span class="avatar avatar-sm">PW</span>
                    <div class="agent-info">
                        <div class="agent-name">Piotr Wiśniewski</div>
                        <div class="agent-meta">Nowy Sącz · 11 transakcji</div>
                    </div>
                    <div class="agent-bar"><div class="progress"><div class="progress-bar" style="width: 60%;"></div></div></div>
                    <div class="agent-value">1.85 mln</div>
                </div>
                <div class="agent-row">
                    <span class="avatar avatar-sm">MK</span>
                    <div class="agent-info">
                        <div class="agent-name">Magdalena Kaczmarek</div>
                        <div class="agent-meta">Tarnów · 7 transakcji</div>
                    </div>
                    <div class="agent-bar"><div class="progress"><div class="progress-bar" style="width: 35%;"></div></div></div>
                    <div class="agent-value">985 tys.</div>
                </div>
                <div class="agent-row">
                    <span class="avatar avatar-sm">JL</span>
                    <div class="agent-info">
                        <div class="agent-name">Jakub Lewandowski</div>
                        <div class="agent-meta">Zakopane · 5 transakcji</div>
                    </div>
                    <div class="agent-bar"><div class="progress"><div class="progress-bar" style="width: 25%;"></div></div></div>
                    <div class="agent-value">720 tys.</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Statystyki ofert -->
<div class="panel">
    <div class="panel-head">
        <h5>Statystyki ofert według kategorii</h5>
        <span class="text-muted small">Stan na: 2026-04-18</span>
    </div>
    <div class="table-responsive">
        <table class="table mb-0">
            <thead>
                <tr>
                    <th>Kategoria</th>
                    <th>Aktywnych</th>
                    <th>Nowych w m-cu</th>
                    <th>Sprzedanych</th>
                    <th>Średnia cena</th>
                    <th>Średni czas sprzedaży</th>
                    <th>Trend</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td><i class="bi bi-house-door-fill text-primary me-2"></i><strong>Mieszkania</strong></td>
                    <td>184</td>
                    <td>27</td>
                    <td>22</td>
                    <td>485 000 zł</td>
                    <td>38 dni</td>
                    <td><span class="badge-status active">+12%</span></td>
                </tr>
                <tr>
                    <td><i class="bi bi-houses-fill text-primary me-2"></i><strong>Domy</strong></td>
                    <td>92</td>
                    <td>14</td>
                    <td>8</td>
                    <td>1 180 000 zł</td>
                    <td>62 dni</td>
                    <td><span class="badge-status active">+8%</span></td>
                </tr>
                <tr>
                    <td><i class="bi bi-tree-fill text-primary me-2"></i><strong>Działki</strong></td>
                    <td>48</td>
                    <td>6</td>
                    <td>3</td>
                    <td>340 000 zł</td>
                    <td>85 dni</td>
                    <td><span class="badge-status away">-2%</span></td>
                </tr>
                <tr>
                    <td><i class="bi bi-shop text-primary me-2"></i><strong>Lokale użytkowe</strong></td>
                    <td>28</td>
                    <td>3</td>
                    <td>2</td>
                    <td>1 850 000 zł</td>
                    <td>110 dni</td>
                    <td><span class="badge-status active">+5%</span></td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
