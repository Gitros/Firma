@{
    ViewData["Title"] = "Oferta";
}

<section class="page-header">
    <div class="container">
        <span class="breadcrumb-text">Strona główna · Oferta</span>
        <h1 class="mt-2">Nasza oferta nieruchomości</h1>
        <p class="lead text-white-50 mb-0">Aktualnie 350+ ofert w całej Małopolsce</p>
    </div>
</section>

<section class="section">
    <div class="container">
        <div class="filter-bar">
            <div class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label">Typ</label>
                    <select class="form-select">
                        <option>Wszystkie</option>
                        <option>Mieszkanie</option>
                        <option>Dom</option>
                        <option>Działka</option>
                        <option>Lokal użytkowy</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Lokalizacja</label>
                    <select class="form-select">
                        <option>Wszystkie miasta</option>
                        <option>Nowy Sącz</option>
                        <option>Kraków</option>
                        <option>Tarnów</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Cena od</label>
                    <input type="text" class="form-control" placeholder="0 zł" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Cena do</label>
                    <input type="text" class="form-control" placeholder="∞" />
                </div>
                <div class="col-md-2">
                    <button class="btn btn-brand w-100"><i class="bi bi-funnel me-1"></i> Filtruj</button>
                </div>
            </div>
            <div class="mt-3 pt-3 border-top">
                <span class="text-muted small me-2">Popularne:</span>
                <a href="#" class="filter-pill active">Wszystkie</a>
                <a href="#" class="filter-pill">Nowe inwestycje</a>
                <a href="#" class="filter-pill">Z ogrodem</a>
                <a href="#" class="filter-pill">Pod wynajem</a>
                <a href="#" class="filter-pill">Premium</a>
                <a href="#" class="filter-pill">Centrum</a>
            </div>
        </div>

        <div class="d-flex justify-content-between align-items-center mb-4">
            <p class="mb-0 text-muted">Znaleziono <strong>6</strong> ofert</p>
            <select class="form-select" style="width: auto;">
                <option>Sortuj: Najnowsze</option>
                <option>Cena rosnąco</option>
                <option>Cena malejąco</option>
                <option>Powierzchnia</option>
            </select>
        </div>

        <div class="row g-4">
            <div class="col-md-6 col-lg-4">
                <div class="property-card">
                    <div class="property-img"><span class="property-badge">Nowość</span><i class="bi bi-house-door-fill"></i></div>
                    <div class="property-body">
                        <div class="property-price">685 000 zł</div>
                        <h5 class="property-title">Apartament z widokiem na góry</h5>
                        <div class="property-loc"><i class="bi bi-geo-alt"></i> Zakopane, Centrum</div>
                        <div class="property-meta">
                            <span><i class="bi bi-arrows-fullscreen"></i>78 m²</span>
                            <span><i class="bi bi-door-open"></i>3 pokoje</span>
                            <span><i class="bi bi-building"></i>2 piętro</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="property-card">
                    <div class="property-img"><span class="property-badge">Premium</span><i class="bi bi-houses-fill"></i></div>
                    <div class="property-body">
                        <div class="property-price">1 250 000 zł</div>
                        <h5 class="property-title">Dom z ogrodem, garaż dwustanowiskowy</h5>
                        <div class="property-loc"><i class="bi bi-geo-alt"></i> Nowy Sącz, Biegonice</div>
                        <div class="property-meta">
                            <span><i class="bi bi-arrows-fullscreen"></i>180 m²</span>
                            <span><i class="bi bi-door-open"></i>5 pokoi</span>
                            <span><i class="bi bi-tree"></i>800 m²</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="property-card">
                    <div class="property-img"><span class="property-badge">Inwestycja</span><i class="bi bi-building"></i></div>
                    <div class="property-body">
                        <div class="property-price">425 000 zł</div>
                        <h5 class="property-title">Mieszkanie inwestycyjne pod wynajem</h5>
                        <div class="property-loc"><i class="bi bi-geo-alt"></i> Kraków, Podgórze</div>
                        <div class="property-meta">
                            <span><i class="bi bi-arrows-fullscreen"></i>42 m²</span>
                            <span><i class="bi bi-door-open"></i>2 pokoje</span>
                            <span><i class="bi bi-cash-coin"></i>2400 zł/mc</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="property-card">
                    <div class="property-img"><span class="property-badge">Działka</span><i class="bi bi-tree-fill"></i></div>
                    <div class="property-body">
                        <div class="property-price">320 000 zł</div>
                        <h5 class="property-title">Działka budowlana z mediami</h5>
                        <div class="property-loc"><i class="bi bi-geo-alt"></i> Stary Sącz, Podegrodzie</div>
                        <div class="property-meta">
                            <span><i class="bi bi-arrows-fullscreen"></i>1200 m²</span>
                            <span><i class="bi bi-water"></i>media</span>
                            <span><i class="bi bi-signpost"></i>droga</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="property-card">
                    <div class="property-img"><span class="property-badge">Premium</span><i class="bi bi-shop"></i></div>
                    <div class="property-body">
                        <div class="property-price">2 800 000 zł</div>
                        <h5 class="property-title">Lokal użytkowy w centrum</h5>
                        <div class="property-loc"><i class="bi bi-geo-alt"></i> Tarnów, Rynek</div>
                        <div class="property-meta">
                            <span><i class="bi bi-arrows-fullscreen"></i>250 m²</span>
                            <span><i class="bi bi-shop"></i>parter</span>
                            <span><i class="bi bi-window"></i>witryna</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="property-card">
                    <div class="property-img"><span class="property-badge">Okazja</span><i class="bi bi-house-fill"></i></div>
                    <div class="property-body">
                        <div class="property-price">389 000 zł</div>
                        <h5 class="property-title">Mieszkanie do remontu, balkon</h5>
                        <div class="property-loc"><i class="bi bi-geo-alt"></i> Nowy Sącz, Centrum</div>
                        <div class="property-meta">
                            <span><i class="bi bi-arrows-fullscreen"></i>56 m²</span>
                            <span><i class="bi bi-door-open"></i>3 pokoje</span>
                            <span><i class="bi bi-building"></i>4 piętro</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <nav class="mt-5 d-flex justify-content-center">
            <ul class="pagination">
                <li class="page-item disabled"><a class="page-link" href="#"><i class="bi bi-chevron-left"></i></a></li>
                <li class="page-item active"><a class="page-link" href="#">1</a></li>
                <li class="page-item"><a class="page-link" href="#">2</a></li>
                <li class="page-item"><a class="page-link" href="#">3</a></li>
                <li class="page-item"><a class="page-link" href="#">…</a></li>
                <li class="page-item"><a class="page-link" href="#">12</a></li>
                <li class="page-item"><a class="page-link" href="#"><i class="bi bi-chevron-right"></i></a></li>
            </ul>
        </nav>
    </div>
</section>
