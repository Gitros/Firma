@{
    ViewData["Title"] = "O nas";
}

<section class="page-header">
    <div class="container">
        <span class="breadcrumb-text">Strona główna · O nas</span>
        <h1 class="mt-2">Poznaj NieruchomościPro</h1>
        <p class="lead text-white-50 mb-0">Lokalna pasja, profesjonalne podejście od 2005 roku</p>
    </div>
</section>

<!-- Misja -->
<section class="section section-light">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-md-6">
                <span class="eyebrow" style="color: var(--accent); font-size: 0.85rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.15em;">Nasza misja</span>
                <h2 class="mt-2">Nieruchomości to coś więcej niż transakcja</h2>
                <p class="text-muted mt-3">Wierzymy, że każdy zasługuje na miejsce, które naprawdę nazwie domem. Naszą misją jest sprawienie, by proces zakupu, sprzedaży lub wynajmu nieruchomości był prostszy, bezpieczniejszy i bardziej ludzki.</p>
                <p class="text-muted">Nie liczymy tylko prowizji — liczymy uśmiechy zadowolonych rodzin, które wprowadzają się do nowych domów. Każda historia ma znaczenie.</p>
                <blockquote class="border-start border-3 ps-3 mt-4" style="border-color: var(--accent) !important;">
                    <em class="text-muted">"Nasi klienci nie są transakcjami. Są częścią naszej historii."</em>
                    <footer class="text-muted small mt-2">— Marcin Wójcik, Założyciel</footer>
                </blockquote>
            </div>
            <div class="col-md-6">
                <div class="image-placeholder"><i class="bi bi-key-fill"></i></div>
            </div>
        </div>
    </div>
</section>

<!-- Wartości -->
<section class="section">
    <div class="container">
        <div class="section-title">
            <span class="eyebrow">Co nas wyróżnia</span>
            <h2>Nasze wartości</h2>
            <p>Trzy filary, na których zbudowaliśmy zaufanie tysięcy klientów.</p>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="value-card">
                    <i class="bi bi-heart-fill icon-big"></i>
                    <h4>Pasja</h4>
                    <p class="text-muted">Kochamy to, co robimy. Każdą ofertę traktujemy tak, jakby była dla naszej rodziny.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="value-card">
                    <i class="bi bi-handshake-fill icon-big"></i>
                    <h4>Uczciwość</h4>
                    <p class="text-muted">Pełna przejrzystość, jasne warunki, brak ukrytych kosztów. Mówimy prawdę nawet gdy jest niewygodna.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="value-card">
                    <i class="bi bi-mortarboard-fill icon-big"></i>
                    <h4>Profesjonalizm</h4>
                    <p class="text-muted">Certyfikowani agenci, prawnicy, rzeczoznawcy. Stałe szkolenia, najnowsze narzędzia, najlepsze praktyki.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Historia (timeline) -->
<section class="section section-light">
    <div class="container">
        <div class="section-title">
            <span class="eyebrow">Nasza droga</span>
            <h2>Historia firmy</h2>
        </div>
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="timeline">
                    <div class="timeline-item">
                        <div class="timeline-year">2005</div>
                        <h5 class="mt-1">Początek przygody</h5>
                        <p class="text-muted">Marcin Wójcik otwiera małe biuro przy ul. Krakowskiej w Nowym Sączu. Trzech agentów, jedno biurko, wielkie marzenia.</p>
                    </div>
                    <div class="timeline-item">
                        <div class="timeline-year">2011</div>
                        <h5 class="mt-1">Pierwszy oddział w Krakowie</h5>
                        <p class="text-muted">Otwarcie nowoczesnego biura w sercu Kazimierza. Zespół rośnie do 12 osób.</p>
                    </div>
                    <div class="timeline-item">
                        <div class="timeline-year">2017</div>
                        <h5 class="mt-1">Nagroda "Agencja Roku"</h5>
                        <p class="text-muted">Pierwsza z czterech nagród przyznanych przez Polską Federację Rynku Nieruchomości.</p>
                    </div>
                    <div class="timeline-item">
                        <div class="timeline-year">2022</div>
                        <h5 class="mt-1">Cyfrowa transformacja</h5>
                        <p class="text-muted">Wdrożenie własnej platformy do wirtualnych spacerów 3D oraz wycen AI. Pionierzy w regionie.</p>
                    </div>
                    <div class="timeline-item">
                        <div class="timeline-year">Dziś</div>
                        <h5 class="mt-1">28 agentów, 4 oddziały, jedna pasja</h5>
                        <p class="text-muted">Nowy Sącz, Kraków, Tarnów, Zakopane. Tysiące zadowolonych klientów. I to dopiero początek.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Zespół -->
<section class="section">
    <div class="container">
        <div class="section-title">
            <span class="eyebrow">Ludzie z pasją</span>
            <h2>Nasz zespół</h2>
            <p>Poznaj liderów, którzy odpowiadają za nasz sukces.</p>
        </div>
        <div class="row g-4">
            <div class="col-6 col-md-3">
                <div class="team-card">
                    <div class="team-avatar">MW</div>
                    <div class="team-name">Marcin Wójcik</div>
                    <div class="team-role">Założyciel · CEO</div>
                    <p class="text-muted small">19 lat na rynku, ekspert ds. inwestycji premium.</p>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="team-card">
                    <div class="team-avatar">AK</div>
                    <div class="team-name">Anna Kowalska</div>
                    <div class="team-role">Dyrektor Sprzedaży</div>
                    <p class="text-muted small">Specjalistka rynku premium w Małopolsce.</p>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="team-card">
                    <div class="team-avatar">PN</div>
                    <div class="team-name">Piotr Nowak</div>
                    <div class="team-role">Główny Prawnik</div>
                    <p class="text-muted small">Prawo nieruchomości, transakcje korporacyjne.</p>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="team-card">
                    <div class="team-avatar">KZ</div>
                    <div class="team-name">Katarzyna Zając</div>
                    <div class="team-role">Marketing</div>
                    <p class="text-muted small">Strategia, kampanie cyfrowe, branding.</p>
                </div>
            </div>
        </div>
    </div>
</section>
