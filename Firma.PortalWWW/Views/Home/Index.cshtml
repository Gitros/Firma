@{
    ViewData["Title"] = "Strona główna";
}

<section class="hero">
    <div class="container hero-content">
        <div class="row">
            <div class="col-lg-8">
                <span class="badge bg-warning text-dark mb-3 px-3 py-2">Nr 1 w regionie · Od 2005 roku</span>
                <h1>Znajdź <span class="accent">wymarzony dom</span><br />razem z nami</h1>
                <p class="lead">Profesjonalne doradztwo, ekskluzywne oferty mieszkań, domów i działek inwestycyjnych. Pomogliśmy ponad 2500 rodzinom znaleźć ich nowy adres.</p>
                <div class="d-flex flex-wrap gap-2 mt-4">
                    <a class="btn btn-accent" asp-controller="Home" asp-action="Oferta"><i class="bi bi-search me-2"></i>Przeglądaj oferty</a>
                    <a class="btn btn-outline-light-brand" asp-controller="Home" asp-action="Kontakt"><i class="bi bi-chat-dots me-2"></i>Skontaktuj się</a>
                </div>

                <div class="hero-search">
                    <div class="row g-2">
                        <div class="col-md-3">
                            <select class="form-select">
                                <option>Typ nieruchomości</option>
                                <option>Mieszkanie</option>
                                <option>Dom</option>
                                <option>Działka</option>
                                <option>Lokal użytkowy</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <select class="form-select">
                                <option>Lokalizacja</option>
                                <option>Nowy Sącz</option>
                                <option>Kraków</option>
                                <option>Tarnów</option>
                                <option>Zakopane</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <select class="form-select">
                                <option>Cena maks.</option>
                                <option>do 300 000 zł</option>
                                <option>do 500 000 zł</option>
                                <option>do 800 000 zł</option>
                                <option>powyżej 1 mln zł</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <button class="btn btn-brand w-100"><i class="bi bi-search me-1"></i> Szukaj</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="section section-light">
    <div class="container">
        <div class="section-title">
            <span class="eyebrow">Dlaczego nieruchomościPro</span>
            <h2>Doświadczenie, które ma znaczenie</h2>
            <p>Łączymy nowoczesne technologie z osobistym podejściem do każdego klienta. Twoja nieruchomość to nasza odpowiedzialność.</p>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="feature-card">
                    <div class="feature-icon"><i class="bi bi-shield-check"></i></div>
                    <h4>Pełne bezpieczeństwo</h4>
                    <p>Każda transakcja zabezpieczona prawnie przez naszych doświadczonych prawników i notariuszy współpracujących.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card">
                    <div class="feature-icon"><i class="bi bi-graph-up-arrow"></i></div>
                    <h4>Najlepsze ceny rynkowe</h4>
                    <p>Profesjonalne wyceny oparte o rzeczywiste dane transakcyjne i analizę trendów lokalnego rynku.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card">
                    <div class="feature-icon"><i class="bi bi-people-fill"></i></div>
                    <h4>Dedykowany agent</h4>
                    <p>Indywidualny opiekun przez cały proces — od pierwszego oglądania, aż po podpisanie aktu notarialnego.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="section">
    <div class="container">
        <div class="section-title">
            <span class="eyebrow">Polecane oferty</span>
            <h2>Wyróżnione nieruchomości</h2>
            <p>Wybór naszych ekspertów — najciekawsze propozycje z aktualnej oferty.</p>
        </div>
        <div class="row g-4">
            <div class="col-md-6 col-lg-4">
                <div class="property-card">
                    <div class="property-img">
                        <span class="property-badge">Nowość</span>
                        <i class="bi bi-house-door-fill"></i>
                    </div>
                    <div class="property-body">
                        <div class="property-price">685 000 zł</div>
                        <h5 class="property-title">Apartament z widokiem na góry</h5>
                        <div class="property-loc"><i class="bi bi-geo-alt"></i> Zakopane, Centrum</div>
                        <div class="property-meta">
                            <span><i class="bi bi-arrows-fullscreen"></i>78 m²</span>
                            <span><i class="bi bi-door-open"></i>3 pokoje</span>
                            <span><i class="bi bi-building"></i>2 piętro</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="property-card">
                    <div class="property-img">
                        <span class="property-badge">Premium</span>
                        <i class="bi bi-houses-fill"></i>
                    </div>
                    <div class="property-body">
                        <div class="property-price">1 250 000 zł</div>
                        <h5 class="property-title">Dom z ogrodem, garaż dwustanowiskowy</h5>
                        <div class="property-loc"><i class="bi bi-geo-alt"></i> Nowy Sącz, Biegonice</div>
                        <div class="property-meta">
                            <span><i class="bi bi-arrows-fullscreen"></i>180 m²</span>
                            <span><i class="bi bi-door-open"></i>5 pokoi</span>
                            <span><i class="bi bi-tree"></i>800 m²</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="property-card">
                    <div class="property-img">
                        <span class="property-badge">Inwestycja</span>
                        <i class="bi bi-building"></i>
                    </div>
                    <div class="property-body">
                        <div class="property-price">425 000 zł</div>
                        <h5 class="property-title">Mieszkanie inwestycyjne pod wynajem</h5>
                        <div class="property-loc"><i class="bi bi-geo-alt"></i> Kraków, Podgórze</div>
                        <div class="property-meta">
                            <span><i class="bi bi-arrows-fullscreen"></i>42 m²</span>
                            <span><i class="bi bi-door-open"></i>2 pokoje</span>
                            <span><i class="bi bi-cash-coin"></i>2400 zł/mc</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="text-center mt-5">
            <a class="btn btn-brand btn-lg" asp-controller="Home" asp-action="Oferta">Zobacz wszystkie oferty <i class="bi bi-arrow-right ms-1"></i></a>
        </div>
    </div>
</section>

<!-- Stats strip -->
<section class="stats-strip">
    <div class="container">
        <div class="row g-4">
            <div class="col-6 col-md-3">
                <div class="stat-item">
                    <span class="stat-number">2500+</span>
                    <span class="stat-label">Zadowolonych klientów</span>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-item">
                    <span class="stat-number">19</span>
                    <span class="stat-label">Lat doświadczenia</span>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-item">
                    <span class="stat-number">350+</span>
                    <span class="stat-label">Aktywnych ofert</span>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-item">
                    <span class="stat-number">28</span>
                    <span class="stat-label">Agentów w zespole</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- O nas teaser -->
<section class="section section-light">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-md-6">
                <div class="image-placeholder"><i class="bi bi-buildings"></i></div>
            </div>
            <div class="col-md-6">
                <span class="eyebrow" style="color: var(--accent); font-size: 0.85rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.15em;">O firmie</span>
                <h2 class="mt-2">Tworzymy historię, jeden dom na raz</h2>
                <p class="text-muted mt-3">NieruchomościPro to lokalna firma z globalnym podejściem. Od prawie dwóch dekad pomagamy mieszkańcom Małopolski i okolic w najważniejszych życiowych decyzjach związanych z nieruchomościami.</p>
                <p class="text-muted">Nasz zespół to certyfikowani agenci, prawnicy, rzeczoznawcy i doradcy kredytowi — wszystko, czego potrzebujesz w jednym miejscu.</p>
                <a class="btn btn-brand mt-3" asp-controller="Home" asp-action="ONas">Poznaj nasz zespół <i class="bi bi-arrow-right ms-1"></i></a>
            </div>
        </div>
    </div>
</section>
