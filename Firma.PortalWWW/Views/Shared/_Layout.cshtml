@{
    var act = ViewContext.RouteData.Values["action"]?.ToString();
    string Active(string a) => act == a ? "active" : "";
}
<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - NieruchomościPro</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Firma.PortalWWW.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm sticky-top portal-nav">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-house-heart-fill brand-icon me-2"></i>
                    <span class="brand-text">Nieruchomości<span class="brand-accent">Pro</span></span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Przełącz nawigację">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav ms-auto align-items-lg-center">
                        <li class="nav-item"><a class="nav-link @Active("Index")" asp-controller="Home" asp-action="Index">Strona główna</a></li>
                        <li class="nav-item"><a class="nav-link @Active("Oferta")" asp-controller="Home" asp-action="Oferta">Oferta</a></li>
                        <li class="nav-item"><a class="nav-link @Active("ONas")" asp-controller="Home" asp-action="ONas">O nas</a></li>
                        <li class="nav-item"><a class="nav-link @Active("Kontakt")" asp-controller="Home" asp-action="Kontakt">Kontakt</a></li>
                        <li class="nav-item ms-lg-3"><a class="btn btn-brand" asp-controller="Home" asp-action="Kontakt"><i class="bi bi-telephone-fill me-1"></i> Umów spotkanie</a></li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="portal-footer">
        <div class="container py-5">
            <div class="row g-4">
                <div class="col-lg-4">
                    <h5 class="footer-brand"><i class="bi bi-house-heart-fill me-2"></i>NieruchomościPro</h5>
                    <p class="text-muted small mt-3">Twój zaufany partner na rynku nieruchomości od 2005 roku. Pomagamy znaleźć wymarzone miejsce do życia i inwestowania.</p>
                    <div class="social-icons mt-3">
                        <a href="#" aria-label="Facebook"><i class="bi bi-facebook"></i></a>
                        <a href="#" aria-label="Instagram"><i class="bi bi-instagram"></i></a>
                        <a href="#" aria-label="LinkedIn"><i class="bi bi-linkedin"></i></a>
                        <a href="#" aria-label="YouTube"><i class="bi bi-youtube"></i></a>
                    </div>
                </div>
                <div class="col-6 col-lg-2">
                    <h6 class="footer-heading">Nawigacja</h6>
                    <ul class="footer-links">
                        <li><a asp-controller="Home" asp-action="Index">Strona główna</a></li>
                        <li><a asp-controller="Home" asp-action="Oferta">Oferta</a></li>
                        <li><a asp-controller="Home" asp-action="ONas">O nas</a></li>
                        <li><a asp-controller="Home" asp-action="Kontakt">Kontakt</a></li>
                    </ul>
                </div>
                <div class="col-6 col-lg-3">
                    <h6 class="footer-heading">Usługi</h6>
                    <ul class="footer-links">
                        <li><a href="#">Sprzedaż nieruchomości</a></li>
                        <li><a href="#">Wynajem długoterminowy</a></li>
                        <li><a href="#">Doradztwo inwestycyjne</a></li>
                        <li><a href="#">Wycena nieruchomości</a></li>
                    </ul>
                </div>
                <div class="col-lg-3">
                    <h6 class="footer-heading">Kontakt</h6>
                    <ul class="footer-contact">
                        <li><i class="bi bi-geo-alt-fill"></i> ul. Krakowska 12, 33-300 Nowy Sącz</li>
                        <li><i class="bi bi-telephone-fill"></i> +48 18 123 45 67</li>
                        <li><i class="bi bi-envelope-fill"></i> kontakt@nieruchomosciPro.pl</li>
                        <li><i class="bi bi-clock-fill"></i> Pn-Pt: 9:00 - 18:00</li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="footer-bottom">
            <div class="container d-flex flex-wrap justify-content-between align-items-center py-3">
                <span class="small">© @DateTime.Now.Year NieruchomościPro. Wszelkie prawa zastrzeżone.</span>
                <span class="small">Polityka prywatności · Regulamin</span>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
